{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "baseUrl": "src",
    "lib": ["dom"],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "exclude": ["./node_modules"],
  "include": ["src/"]
}
